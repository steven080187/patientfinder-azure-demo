PORT=3001
AZURE_API_ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql://username:password@hostname:5432/patientfinder
ENTRA_TENANT_ID=
# API App Registration Application (client) ID
ENTRA_API_CLIENT_ID=
# Optional comma-separated audiences if you need to accept multiple values.
# Example: api://<api-client-id>,<api-client-id>
ENTRA_API_AUDIENCES=
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=patientfinder-documents
AZURE_BLOB_BASE_PATH=patient-documents
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
